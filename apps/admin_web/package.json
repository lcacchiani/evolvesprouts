{
  "name": "admin-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "generate:phone-countries": "node ../../scripts/generate-phone-countries.mjs",
    "prebuild": "npm run generate:phone-countries && npm run generate:admin-api-types",
    "generate:admin-api-types": "openapi-typescript ../../docs/api/admin.yaml -o src/types/generated/admin-api.generated.ts",
    "check:admin-api-types": "node ./scripts/check-admin-api-types.mjs",
    "lint": "npm run check:admin-api-types && eslint --max-warnings=0 .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "amazon-cognito-identity-js": "^6.3.18",
    "clsx": "^2.1.1",
    "next": "^16.2.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^29.1.1",
    "libphonenumber-js": "^1.13.7",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "vitest": {
      "vite": "$vite"
    },
    "typescript-eslint": "8.58.0",
    "js-yaml": "^4.2.0",
    "@redocly/openapi-core": {
      "minimatch": "5.1.8"
    },
    "flatted": "^3.4.0",
    "js-cookie": "^3.0.7",
    "openapi-typescript": {
      "typescript": "$typescript"
    }
  }
}
