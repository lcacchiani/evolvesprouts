{
  "name": "admin-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "generate:phone-countries": "node ../../scripts/generate-phone-countries.mjs",
    "prebuild": "npm run generate:phone-countries && npm run generate:admin-api-types",
    "generate:admin-api-types": "openapi-typescript ../../docs/api/admin.yaml -o src/types/generated/admin-api.generated.ts",
    "check:admin-api-types": "node ./scripts/check-admin-api-types.mjs",
    "lint": "npm run check:admin-api-types && eslint --max-warnings=0 .",
    "test": "vitest run"
  },
  "dependencies": {
    "amazon-cognito-identity-js": "^6.3.16",
    "clsx": "^2.1.1",
    "next": "^16.2.4",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.0.2",
    "libphonenumber-js": "^1.12.41",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "typescript-eslint": "8.57.2",
    "js-yaml": "^4.1.1",
    "@redocly/openapi-core": {
      "minimatch": "5.1.8"
    },
    "flatted": "^3.4.0",
    "openapi-typescript": {
      "typescript": "$typescript"
    }
  }
}
